{
  "name": "giaom-marketplace",
  "version": "1.0.0",
  "type": "module",
  "description": "Giaom Marketplace - React Frontend",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview --host 0.0.0.0 --port 3000",
    "start": "serve -s dist -l 3000",
    "pm2:start": "pm2 start ecosystem.config.cjs --only giaom-client",
    "pm2:stop": "pm2 stop giaom-client",
    "pm2:restart": "pm2 restart giaom-client",
    "pm2:delete": "pm2 delete giaom-client",
    "pm2:logs": "pm2 logs giaom-client",
    "pm2:status": "pm2 status giaom-client",
    "pm2:build-and-start": "npm run build && pm2 start ecosystem.config.cjs --only giaom-client",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-dialog": "^1.0.5",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.0.2",
    "@radix-ui/react-select": "^2.0.0",
    "@radix-ui/react-slot": "^1.0.2",
    "@radix-ui/react-tabs": "^1.0.4",
    "@radix-ui/react-toast": "^1.1.5",
    "@stripe/react-stripe-js": "^5.6.0",
    "@stripe/stripe-js": "^8.8.0",
    "axios": "^1.6.2",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.0.0",
    "lucide-react": "^0.294.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-hook-form": "^7.48.2",
    "react-router-dom": "^6.21.1",
    "recharts": "^3.7.0",
    "tailwind-merge": "^2.0.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@typescript-eslint/eslint-plugin": "^6.14.0",
    "@typescript-eslint/parser": "^6.14.0",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.4.16",
    "eslint": "^8.55.0",
    "eslint-plugin-react-hooks": "^4.6.0",
    "eslint-plugin-react-refresh": "^0.4.5",
    "pm2": "^5.3.0",
    "postcss": "^8.4.32",
    "rollup-plugin-visualizer": "^6.0.5",
    "serve": "^14.2.1",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.2.2",
    "vite": "^7.3.1"
  }
}
